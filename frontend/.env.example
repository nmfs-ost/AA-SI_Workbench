# Copy to `.env.local` to point the NCEI panel at the real backend API.
# With this unset, the panel uses built-in deterministic mock data.

# Use the real backend instead of mock data:
VITE_AASI_USE_API=true

# Base URL for the backend API. Leave empty to call same-origin `/api/...`,
# which the dev server forwards to the backend via its proxy (recommended).
# Set an absolute URL only if you are NOT using the dev proxy (needs CORS).
# VITE_AASI_API_BASE=

# Where the dev proxy forwards `/api` (default http://localhost:8000):
# VITE_AASI_API_PROXY=http://localhost:8000

# Where "Report a Problem" / "Suggest an Improvement" file issues. Defaults to
# nmfs-ost/AA-SI_Workbench; override only for a fork.
# VITE_AASI_GITHUB_ORG=nmfs-ost
# VITE_AASI_GITHUB_REPO=AA-SI_Workbench
