# --- AA-SI Workbench backend configuration ---

# Which NCEI catalog source the API serves from:
#   s3     (default) anonymous listing of the public noaa-wcsd-pds bucket (no creds)
#   cache  BigQuery metadata.ncei_cache table (fast; needs the GCP creds below)
AASI_NCEI_SOURCE=s3

# CORS origins allowed to call the API directly (comma-separated). Not needed
# when the frontend reaches the API through the Vite dev proxy (the default).
AASI_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Only required when AASI_NCEI_SOURCE=cache (BigQuery) ---
# GCP project that owns the ncei_cache table.
AALIBRARY_GCP_PROJECT_ID=ggn-nmfs-aa-dev-1
# Either run `gcloud auth application-default login` (recommended) and leave the
# line below unset, or point it at a service-account key file.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
