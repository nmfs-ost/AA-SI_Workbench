# --- AA-SI Workbench backend configuration ---

# Which NCEI catalog source the API serves from:
#   s3     (default) anonymous listing of the public noaa-wcsd-pds bucket (no creds)
#   cache  BigQuery metadata.ncei_cache table (fast; needs the GCP creds below)
AASI_NCEI_SOURCE=s3

# CORS origins allowed to call the API directly (comma-separated). Not needed
# when the frontend reaches the API through the Vite dev proxy (the default).
AASI_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Only required when AASI_NCEI_SOURCE=cache (BigQuery) ---
# GCP project that owns the ncei_cache table.
AALIBRARY_GCP_PROJECT_ID=ggn-nmfs-aa-dev-1
# Either run `gcloud auth application-default login` (recommended) and leave the
# line below unset, or point it at a service-account key file.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Environment updater (Tools -> Update Python Environment) ---
# The command the updater runs. Parsed with shlex; argv[0] is resolved against
# this virtualenv's bin/ before PATH. Never taken from the browser.
# AASI_UPDATE_COMMAND=aa-setup
# Virtualenv name the UI expects; a mismatch is surfaced as a warning.
# AASI_EXPECTED_VENV=venv313
# Distributions to report versions for in the environment dialog.
# AASI_ENV_WATCH_PACKAGES=aalibrary,echopype,xarray,numpy,aa-si-workbench
# The updater refuses to run when the server is bound off-loopback (aa-workbench
# publishes the bind host as AASI_BIND_HOST). Only set this on a trusted host.
# AASI_ALLOW_REMOTE_UPDATE=false

# --- Terminal (bottom dock) ---
# A terminal is arbitrary code execution by design, so it refuses to open when
# the server is bound off-loopback. Only set this on a trusted host.
# AASI_ALLOW_REMOTE_TERMINAL=false
# Shell to launch (defaults to $SHELL, then /bin/bash).
# AASI_TERMINAL_SHELL=/bin/bash
# Extra virtualenv locations to offer, separated by ':'.
# AASI_VENV_SEARCH=/opt/envs/aa:/srv/venvs/shared

# --- Files panel ---
# Browsing is confined to this directory. Set to / for the whole machine.
# AASI_FS_ROOT=$HOME
# AASI_ALLOW_REMOTE_FS=false

# --- Derived assets (GCS bucket holding pipeline output) ---
# Needs: pip install google-cloud-storage, and `gcloud auth application-default login`.
# AASI_DERIVED_BUCKET=ggn-nmfs-aa-dev-1-data
# Treat a sub-path as the root of the panel, e.g. derived/
# AASI_DERIVED_PREFIX=
# Project used for billing/quota (shared with aalibrary).
# AALIBRARY_GCP_PROJECT_ID=ggn-nmfs-aa-dev-1

# --- Recipes (aa-recipe-manager integration) ---------------------------------
# Where recipe YAML files are discovered. When unset, the first existing of
# ~/AA-SI_recipe_manager/example_recipes and ~/recipes is used, else the
# examples bundled with the Workbench (verbatim copies of aa-recipe-manager's
# example_recipes; see src/aa_si_workbench/builtin_recipes/README.md).
#AASI_RECIPES_DIR=
# The listing reads the filesystem, so it follows the same loopback rule as
# the other machine-touching routes.
#AASI_ALLOW_REMOTE_RECIPES=false
